DATABASE_URL=postgresql://trackyr:trackyr@localhost:5434/trackyr
SAMPLE_INTERVAL=5
IDLE_THRESHOLD=300
BUFFER_MAX_SIZE=1000
LOG_LEVEL=INFO

# Email (Gmail SMTP — use an App Password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_TO=your-email@gmail.com

# API server
API_PORT=8099

# Scheduler
DAILY_REPORT_HOUR=21
WEEKLY_REPORT_DAY=sun
WEEKLY_REPORT_HOUR=21

# Webhooks (OpenClaw integration)
WEBHOOK_URL=http://127.0.0.1:18789/tools/invoke
WEBHOOK_ENABLED=false

# Device identifier (for multi-device setups)
DEVICE_ID=default
